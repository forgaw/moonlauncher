<?xml version="1.0" encoding="UTF-8"?>
<Wix
  xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="moonlauncher"
    Manufacturer="Moonlauncher Team"
    Version="$(var.ProductVersion)"
    UpgradeCode="{F3A86A79-98AA-41E6-A8D8-54D4A4B911F3}"
    Language="1049"
    Scope="perMachine"
    InstallerVersion="500">

    <SummaryInformation
      Description="moonlauncher installer"
      Manufacturer="Moonlauncher Team" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of moonlauncher is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="ARPURLINFOABOUT" Value="https://t.me/luxxxb" />
    <Property Id="ARPCONTACT" Value="@luxxxb Telegram" />
    <WixVariable Id="WixUILicenseRtf" Value="MoonlauncherPrivacyPolicy.rtf" />

    <ui:WixUI Id="WixUI_InstallDir" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="moonlauncher" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuMoonlauncherFolder" Name="moonlauncher" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="moonlauncher" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.ReleaseDir)\**">
        <Exclude Files="$(var.ReleaseDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcutComponent" Directory="ProgramMenuMoonlauncherFolder" Guid="*">
      <Shortcut
        Id="StartMenuMoonlauncherShortcut"
        Name="moonlauncher"
        Description="moonlauncher"
        Target="[INSTALLFOLDER]moonlauncher.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveProgramMenuMoonlauncherFolder" Directory="ProgramMenuMoonlauncherFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\moonlauncher" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="DesktopShortcutComponent" Directory="DesktopFolder" Guid="*">
      <Shortcut
        Id="DesktopMoonlauncherShortcut"
        Name="moonlauncher"
        Description="moonlauncher"
        Target="[INSTALLFOLDER]moonlauncher.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\moonlauncher" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
